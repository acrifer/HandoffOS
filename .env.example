# LifeOS 3.0 - Team Handoff Skill Control Plane

DB_NAME=lifeos
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

REDIS_PORT=6379

APP_PORT=8080
WEB_PORT=5173

JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long

# Demo device quota / admin console.
ADMIN_CONSOLE_KEY=change-me-admin-key
DEMO_DEVICE_TOKEN_LIMIT=100000

# Optional legacy/self-built RAG model configuration.
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_EMBEDDING_MODEL=text-embedding-3-small

# Dify Knowledge + Workflow. Real credentials are required.
DIFY_BASE_URL=http://localhost:5001/v1
DIFY_API_KEY=
DIFY_DISTILL_WORKFLOW_KEY=
DIFY_ASK_APP_KEY=
DIFY_DEMO_MODE=false

# Feishu / Lark OpenAPI. Empty or invalid credentials fail fast.
FEISHU_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_HISTORY_LIMIT=80
FEISHU_DEMO_FALLBACK_ENABLED=false
FEISHU_BOT_ENABLED=false
FEISHU_BOT_LONG_CONNECTION_ENABLED=false
FEISHU_BOT_VERIFICATION_TOKEN=
FEISHU_BOT_ENCRYPT_KEY=
